# Hardcover → Popfeed sync configuration

# Hardcover API token (from https://hardcover.app/account/api)
HARDCOVER_TOKEN=your_hardcover_token_here

# Popfeed / Bluesky account credentials
POPFEED_IDENTIFIER=yourhandle.bsky.social
POPFEED_PASSWORD=your_app_password_here

# Optional: PDS URL (default: https://eurosky.social)
# POPFEED_PDS_URL=https://eurosky.social

# Optional: pre-configured AT URI of your "Books" list on Popfeed.
# If not set, the sync will find or create a list automatically.
# POPFEED_BOOKS_LIST_URI=at://did:plc:xxx/social.popfeed.feed.list/yyyy

# Set to "true" to log actions without writing to Popfeed
# DRY_RUN=false
